# Copy to .env and fill in real values. .env is gitignored — never commit it.
# Alpaca paper-trading credentials (https://app.alpaca.markets/ -> paper account -> API keys)
ALPACA_API_KEY_ID=your_paper_key_id_here
ALPACA_API_SECRET_KEY=your_paper_secret_key_here
# Paper endpoint. Switch to https://api.alpaca.markets only for live (guarded later).
ALPACA_BASE_URL=https://paper-api.alpaca.markets
